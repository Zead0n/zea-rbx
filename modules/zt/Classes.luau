--!strict

local Type = require(script.Parent.Type)

local function robloxClass(obj: string)
	local function matcher(value): (boolean, string?)
		if not value.IsA then
			return false, `'{typeof(value)}' is not of type Object/Instance`
		end

		local valueTypeName = typeof(value)
		if not value:IsA(obj) then
			return false,
				`value is a '{if valueTypeName == "Instance" then value.ClassName else valueTypeName}' Object, expected {obj}`
		end

		return true
	end

	return Type.new("Object", matcher, nil, obj)
end

